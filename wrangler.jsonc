{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pin-gateway-worker",
  "main": "src/worker.js",
  "compatibility_date": "2026-05-15",
  "assets": {
    "binding": "ASSETS",
    "directory": "./public",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  } 
}
